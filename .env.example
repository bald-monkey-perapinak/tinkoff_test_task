GROQ_API_KEY=gsk_your_groq_api_key_here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_WEBAPP_URL=http://localhost:5173

# hh.ru proxy (optional, for bypassing IP blocks)
# HH_PROXY=http://host:port
# HH_PROXY_LIST=proxies.txt

# LLM configuration (optional)
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=2000

# === Deployment (Railway + Vercel) ===
# Backend (Railway): set these env vars in Railway dashboard
#   GROQ_API_KEY=gsk_...
#   TELEGRAM_BOT_TOKEN=...
#   TELEGRAM_WEBAPP_URL=https://your-app.vercel.app
#
# Frontend (Vercel): set this env var in Vercel dashboard
#   VITE_API_URL=https://your-backend.up.railway.app
